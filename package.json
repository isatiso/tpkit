{
    "name": "@tarpit/tpkit",
    "version": "0.6.0",
    "description": "CLI tool for syncing AI agent rules and skills across projects",
    "author": "Cao Jiahang <sieglive@gmail.com>",
    "license": "MIT",
    "type": "module",
    "bin": {
        "tpkit": "./dist/index.js"
    },
    "exports": {
        ".": "./dist/index.js",
        "./cli": "./dist/cli.js"
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "prepublishOnly": "pnpm build",
        "version": "changeset version",
        "publish:ci": "pnpm build && npm publish --access public",
        "tpkit": "node dist/index.js",
        "sync": "node dist/index.js agent sync"
    },
    "dependencies": {
        "chalk": "^5.4.1",
        "commander": "^13.1.0",
        "simple-git": "^3.27.0",
        "yaml": "^2.8.3"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.6",
        "@types/node": "^22.15.3",
        "tsup": "^8.5.0",
        "typescript": "~5.9.2"
    },
    "engines": {
        "node": ">=22"
    }
}
